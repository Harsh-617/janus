# ── Google Cloud ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
VERTEX_AI_LOCATION=us-central1

# ── LLM Provider (Groq) ───────────────────────────────────────
GROQ_API_KEY=your-primary-groq-key
# Optional: add more keys from extra accounts for higher rate limits
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# ── Google Generative AI (kept for future migration) ──────────
GOOGLE_API_KEY=your-google-ai-studio-key-optional

# ── Alpha Vantage (free tier — get key at alphavantage.co) ───
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ── Arize Phoenix ─────────────────────────────────────────────
# Local development:
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_BASE_URL=http://localhost:6006
# Production (fill in after deploying Phoenix to Cloud Run):
# PHOENIX_COLLECTOR_ENDPOINT=https://your-phoenix.run.app/v1/traces
# PHOENIX_BASE_URL=https://your-phoenix.run.app

# ── Gemini Models ─────────────────────────────────────────────
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_JUDGE=gemini-2.0-flash

# ── Firestore ─────────────────────────────────────────────────
FIRESTORE_PORTFOLIO_ID=janus_main
FIRESTORE_DATABASE=(default)

# ── Agent Behaviour ───────────────────────────────────────────
AGENT_CYCLE_INTERVAL_SECONDS=30
JANUS_LOOP_INTERVAL_CYCLES=10
INITIAL_CAPITAL=1000000.0

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
