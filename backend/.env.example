# ── Google Cloud ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
VERTEX_AI_LOCATION=us-central1

# ── Google AI Studio ──────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-studio-key-optional

# ── Groq LLM Keys ─────────────────────────────────────────────
# At minimum GROQ_API_KEY_1 is required. Keys 2-6 are optional and used for automatic rate limit rotation.
GROQ_API_KEY_1=your_primary_key
# GROQ_API_KEY_2=your_second_key  # optional, for rate limit rotation
# GROQ_API_KEY_3=your_third_key   # optional

# ── Alpha Vantage News (add up to 4 keys for rotation) ────────
ALPHA_VANTAGE_API_KEY_1=your-alpha-vantage-key-1
ALPHA_VANTAGE_API_KEY_2=your-alpha-vantage-key-2
ALPHA_VANTAGE_API_KEY_3=your-alpha-vantage-key-3
ALPHA_VANTAGE_API_KEY_4=your-alpha-vantage-key-4

# ── Arize Phoenix ─────────────────────────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_BASE_URL=http://localhost:6006

# ── App Config ────────────────────────────────────────────────
FIRESTORE_PORTFOLIO_ID=janus_main
AGENT_CYCLE_INTERVAL_SECONDS=60
JANUS_LOOP_INTERVAL_CYCLES=10
INITIAL_CAPITAL=1000000.0